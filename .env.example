# ==============================================================================
# HushRag Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# IMPORTANT: Never commit your .env file to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Local Development Mode
# ------------------------------------------------------------------------------
# Set to "true" to bypass organization credentials and use the local SQLite
# database (database.sqlite). This is the easiest way to get started.
LOCAL_MODE=true

# ------------------------------------------------------------------------------
# Encryption Key (REQUIRED for production)
# ------------------------------------------------------------------------------
# Used to encrypt/decrypt LLM API keys and database credentials stored in the
# settings table. MUST be a strong random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=

# ------------------------------------------------------------------------------
# JWT Secret (REQUIRED for production)
# ------------------------------------------------------------------------------
# Secret used to sign and verify JSON Web Tokens for admin authentication.
# MUST be a strong random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# JWT_SECRET=

# ------------------------------------------------------------------------------
# Scheduled Cleanup
# ------------------------------------------------------------------------------
# Set to "false" to disable the automatic 7-day chat transcript purge.
# ENABLE_CLEANUP=true
